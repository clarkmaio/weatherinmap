{
  "manifest_version": 3,
  "name": "Weather Forecast for Google Maps",
  "version": "1.0.0",
  "description": "Click anywhere on Google Maps to see a 15-day ECMWF IFS forecast: temperature, precipitation, cloud cover, and wind.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/maps*",
        "https://maps.google.com/*"
      ],
      "js": [
        "lib/chart.umd.min.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://nominatim.openstreetmap.org/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "lib/*"],
      "matches": ["https://www.google.com/*", "https://maps.google.com/*"]
    }
  ]
}
